{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "rules": [
            {
              "id": "js/sql-injection",
              "name": "SqlInjection",
              "shortDescription": { "text": "SQL injection" },
              "helpUri": "https://example.com/sql-injection",
              "help": { "text": "Use parameterized queries." },
              "defaultConfiguration": { "level": "error" },
              "properties": { "tags": ["security", "external/cwe/cwe-089"] }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "js/sql-injection",
          "ruleIndex": 0,
          "level": "error",
          "message": { "text": "User input reaches SQL query." },
          "partialFingerprints": { "primaryLocationLineHash": "abc123:1" },
          "properties": { "security-severity": "8.8" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/db.js" },
                "region": { "startLine": 42, "startColumn": 13 }
              }
            }
          ],
          "relatedLocations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/router.js" },
                "region": { "startLine": 9 }
              },
              "message": { "text": "user input source" }
            }
          ],
          "codeFlows": [
            {
              "threadFlows": [
                {
                  "locations": [
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": { "uri": "src/router.js" },
                          "region": { "startLine": 9 }
                        },
                        "message": { "text": "source" }
                      }
                    },
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": { "uri": "src/db.js" },
                          "region": { "startLine": 42 }
                        },
                        "message": { "text": "sink" }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
